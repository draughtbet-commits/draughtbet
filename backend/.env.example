# Server configuration
PORT=3000
NODE_ENV=development

# Database configuration
# Set up a local PostgreSQL database and provide the connection URL here
DATABASE_URL="postgresql://user:password@localhost:5432/draughts_arena?schema=public"

# Redis configuration
REDIS_URL="redis://localhost:6379"

# JWT Auth
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="15m"

# Stripe configuration (Sandbox mode initially)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Firebase Cloud Messaging
# Requires downloading a serviceAccountKey.json from Firebase console
FIREBASE_SERVICE_ACCOUNT_KEY="{...}"
